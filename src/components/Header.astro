---
import { existingCategories, labelFor } from "../lib/categories";

const cats = await existingCategories();
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-baseline gap-1 font-display text-2xl font-extrabold text-navy">
      AZ<span class="text-pink">Pet</span>Shop
    </a>
    <nav class="hidden gap-6 md:flex">
      {
        cats.map((c) => (
          <a href={`/blog/${c}`} class="text-sm font-bold text-navy hover:text-pink">
            {labelFor(c)}
          </a>
        ))
      }
    </nav>
    <a
      href="https://www.mypetbrasil.com"
      class="rounded-full bg-navy px-4 py-2 text-xs font-bold text-white hover:bg-navy-700"
    >
      Comprar no atacado
    </a>
  </div>
  {
    cats.length > 0 && (
      <nav class="flex gap-5 overflow-x-auto border-t border-line px-4 py-2 md:hidden">
        {cats.map((c) => (
          <a href={`/blog/${c}`} class="whitespace-nowrap text-sm font-bold text-navy">
            {labelFor(c)}
          </a>
        ))}
      </nav>
    )
  }
</header>
