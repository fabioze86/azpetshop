---
interface Props {
  href: string;
  title: string;
  excerpt: string;
  category: string;
  type?: string;
  hero?: string;
  heroAlt?: string;
}
const { href, title, excerpt, category, type, hero, heroAlt } = Astro.props;
import { labelFor } from "../lib/categories";
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-shadow hover:shadow-md">
  <a href={href} class="block aspect-[16/10] overflow-hidden bg-mist">
    {
      hero ? (
        <img
          src={hero}
          alt={heroAlt ?? title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-4xl text-cyan">🐾</div>
      )
    }
  </a>
  <div class="flex flex-1 flex-col p-5">
    <div class="mb-2 flex items-center gap-2 text-xs font-bold uppercase tracking-wide">
      <span class="text-pink">{labelFor(category)}</span>
      {type === "roundup" && <span class="rounded-full bg-cyan/15 px-2 py-0.5 text-cyan">Comparativo</span>}
    </div>
    <h3 class="text-lg font-extrabold leading-snug text-navy">
      <a href={href} class="hover:text-pink">{title}</a>
    </h3>
    <p class="mt-2 line-clamp-3 flex-1 text-sm text-ink/75">{excerpt}</p>
    <a href={href} class="mt-4 text-sm font-bold text-pink hover:text-pink-600">Ler mais →</a>
  </div>
</article>
